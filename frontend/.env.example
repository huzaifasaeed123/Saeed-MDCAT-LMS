# Copy this file to .env and fill in the values.
# In production these are set in Coolify's environment-variable UI, not in a file.
# Vite ONLY reads variables prefixed with VITE_.

# Where the React app sends API requests.
# Dev: http://localhost:5000/api
# Prod: https://api.sknmdcat.com/api
VITE_API_URL=http://localhost:5000/api

# Used by fixImageUrls.js to prefix backend-served image paths (e.g. /uploads/...).
# Dev: http://localhost:5000
# Prod: https://api.sknmdcat.com
VITE_BACKEND_URL=http://localhost:5000

# Display name shown in the browser tab and a few headings.
VITE_APP_NAME=Saeed MDCAT LMS

# Google Sign-In client ID from Google Cloud Console (OAuth 2.0 credentials).
# Same value across all environments; the authorised origin list in Google
# Cloud Console determines which domains can use it.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

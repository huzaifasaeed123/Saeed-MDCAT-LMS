# Copy this file to .env and fill in the values.
# In production these are set in Coolify's environment-variable UI, not in a file.

# ── Server ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ────────────────────────────────────────────────────────────
# Local dev:  mongodb://localhost:27017/SaeedMdcatLms
# Atlas prod: mongodb+srv://USER:PASS@cluster.mongodb.net/SaeedMdcatLms?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/SaeedMdcatLms

# ── Auth / Tokens ───────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 48
# DIFFERENT secrets per environment. NEVER reuse production secrets in dev.
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string

# ── Google OAuth (Google Sign-In on the frontend) ───────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── Frontend origin (CORS + cookie SameSite + password-reset links) ─────
# Comma-separate multiple origins if you serve from more than one domain.
# Dev:  http://localhost:5173
# Prod: https://test.sknmdcat.com
FRONTEND_URL=http://localhost:5173

# ── Seed admin (auto-created on first boot) ─────────────────────────────
ADMIN_FULLNAME=Root Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_CONTACT=+923001234567

# ── SMTP (password-reset emails) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@gmail.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM_NAME=Saeed MDCAT LMS
